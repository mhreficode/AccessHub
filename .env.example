# Copy this file to .env before running the app:  cp .env.example .env
#
# SQLite database location. The path is resolved relative to prisma/schema.prisma,
# so this points at prisma/dev.db.
DATABASE_URL="file:./dev.db"

# Backend API port
API_PORT=4000

# Set to "development" to enable verbose dev-only code paths.
NODE_ENV=development
