{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "matcher": "apply_patch|create_file|create_directory|edit_notebook_file",
        "type": "command",
        "bash": "STRICT=1 ./scripts/security-check.sh",
        "powershell": "$env:STRICT='1'; ./scripts/security-check.ps1",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}
